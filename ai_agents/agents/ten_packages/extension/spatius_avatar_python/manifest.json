{
  "type": "extension",
  "name": "spatius_avatar_python",
  "version": "0.1.0",
  "dependencies": [
    {
      "type": "system",
      "name": "ten_runtime_python",
      "version": "0.11"
    },
    {
      "type": "system",
      "name": "ten_ai_base",
      "version": "0.7.40"
    }
  ],
  "package": {
    "include": [
      "manifest.json",
      "property.json",
      "**.py",
      "README.md",
      "requirements.txt"
    ]
  },
  "api": {
    "property": {
      "properties": {
        "spatius_api_key": {
          "type": "string"
        },
        "spatius_app_id": {
          "type": "string"
        },
        "spatius_avatar_id": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "agora_avatar_uid": {
          "type": "string"
        },
        "agora_appid": {
          "type": "string"
        },
        "agora_appcert": {
          "type": "string"
        },
        "channel": {
          "type": "string"
        },
        "sample_rate": {
          "type": "int32"
        },
        "session_expire_minutes": {
          "type": "int32"
        },
        "dump": {
          "type": "bool"
        },
        "dump_path": {
          "type": "string"
        }
      }
    },
    "audio_frame_in": [
      {
        "name": "pcm_frame"
      }
    ],
    "data_in": [
      {
        "name": "tts_audio_end"
      }
    ],
    "cmd_in": [
      {
        "name": "flush"
      }
    ]
  },
  "scripts": {
    "test": "tests/bin/start"
  }
}
